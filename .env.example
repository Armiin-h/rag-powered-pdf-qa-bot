# Ollama
OLLAMA_BASE_URL=http://localhost:11434
# Docker Compose: OLLAMA_BASE_URL=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text
CHAT_MODEL=llama3.2

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db
COLLECTION_NAME=pdf_documents

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Retrieval
TOP_K=5
FETCH_K=20

# Uploads (Streamlit)
UPLOAD_DIR=./uploads
